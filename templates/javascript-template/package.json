{
  "name": "@templ-project/javascript-template",
  "version": "1.3.1",
  "description": "A JavaScript Bootstrap/Template project using modern tools and best practices",
  "author": "Templ Project",
  "license": "MIT",
  "type": "module",
  "bin": {
    "bootstrap": ".npx-install/bootstrap.js"
  },
  "bugs": {
    "url": "https://github.com/templ-project/javascript/issues"
  },
  "devDependencies": {
    "@jscpd/badge-reporter": "^4.0.1",
    "@templ-project/eslint": "^1.3.0",
    "@templ-project/prettier": "^1.1.0",
    "@templ-project/vitest": "^0.3.2",
    "@vitest/coverage-v8": "^4.0.13",
    "docdash": "^2.0.2",
    "esbuild": "^0.27.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "licensee": "^11.1.1",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "rimraf": "^6.1.2",
    "typedoc": "0.28.15",
    "typedoc-plugin-markdown": "4.9.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "exports": {
    ".": {
      "browser": {
        "import": "./dist/browser/index.js",
        "default": "./dist/browser/index.js"
      },
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.js"
    }
  },
  "files": [".npx-install", "dist"],
  "homepage": "https://github.com/templ-project/javascript#readme",
  "jsdelivr": "./dist/iife/your-lib.min.js",
  "keywords": [
    "bootstrap",
    "browser",
    "eslint",
    "esm",
    "import-maps",
    "javascript",
    "node",
    "prettier",
    "template",
    "vitest"
  ],
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/templ-project/javascript.git"
  },
  "scripts": {
    "audit-check": "npm audit --audit-level=moderate",
    "build": "run-s build:*",
    "build:browser": "esbuild src/index.js --bundle --format=esm --platform=browser --target=es2018 --outdir=dist/browser --splitting --minify --sourcemap",
    "build:cjs": "esbuild src/index.js --bundle --format=cjs --platform=node --target=node16 --outfile=dist/cjs/index.cjs --sourcemap",
    "build:esm": "esbuild src/index.js --bundle --format=esm --platform=neutral --target=es2020 --outdir=dist/esm --splitting --sourcemap",
    "build:iife": "esbuild src/index.js --bundle --format=iife --platform=browser --target=es2018 --outfile=dist/iife/your-lib.min.js --global-name=YourLib --minify --sourcemap",
    "clean": "rimraf .nyc_output coverage dist docs-html",
    "docs": "typedoc",
    "docs:serve": "npx --yes serve docs-html",
    "duplicate-check": "jscpd src/",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "license-check": "npx licensee --errors-only",
    "lint": "npx eslint --fix .",
    "lint:check": "npx eslint .",
    "prebuild": "run-s clean",
    "pretest": "run-s clean build",
    "serve": "npx --yes serve .",
    "start": "node src/cli.js",
    "start:debug": "node --inspect src/cli.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "validate": "run-s format lint duplicate-check test"
  },
  "sideEffects": false,
  "unpkg": "./dist/iife/your-lib.min.js"
}
